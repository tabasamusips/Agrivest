{
  "name": "@agrivest/api",
  "version": "0.1.0",
  "description": "Agri Vest NestJS API — auth, wallet, investing, M-Pesa webhooks",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit",
    "test:e2e": "tsc -p tsconfig.e2e.json && node --test dist-test/test/*.e2e.js"
  },
  "dependencies": {
    "@agrivest/ledger": "*",
    "@agrivest/marketplace": "*",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^11.1.24",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^11.1.24",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^11.1.24",
    "@types/node": "^22",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "supertest": "^7.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
